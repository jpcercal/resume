<!DOCTYPE html>
<html lang="{{meta.lang}}">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<title>{{basics.name}} — {{basics.label}}</title>

	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400;1,500;1,600;1,700;1,800&display=swap" rel="stylesheet">

	<style>
		{{style}}
	</style>
</head>
<body>
	<div class="page__background-top"></div>

	<header class="basics page__background-header">
		<div class="page__content">
			<div class="basics__identity">

				<div class="flex w-full justify-center items-center mb-6">
					<div class="w-1/4">
						<h1 class="basics__identity-name text-accent font-mono text-xs text-center -ml-2">{{basics.name}}</h1>
					</div>
					<div class="w-1/4">
						<h2 class="basics__identity-label text-gray-400 font-mono text-xs text-center">{{basics.label}}</h2>
					</div>
					<div class="w-1/2">
						<h3 class="basics__identity-mission_statement text-gray-300 font-mono text-xs text-center italic -mr-2">{{ meta.mission_statement }}</h3>
					</div>
				</div>

				{{#if basics.picture}}
				<figure class="basics__photo-figure">
					<img src="{{basics.picture}}"
						alt="{{basics.name}}"
						class="basics__photo"
						width="88"
						height="88">
					<figcaption>Profile photo of {{basics.name}}</figcaption>
				</figure>
				{{/if}}

				<p class="basics__summary">
					<div class="mb-6">
						<span class="text-gray-600 font-medium text-sm">{{basics.summary}}</span>
						<span class="text-accent">&#x2665;</span>
					</div>
				</p>
			</div>
		</div>

		<address class="basics__contacts">
			<div class="max-w-4xl mx-auto px-10 flex flex-wrap justify-center items-center gap-x-8 gap-y-1">

				{{#each basics.profiles}}
				<a href="{{this.url}}" class="contact" rel="noopener noreferrer" target="_blank">
					{{{networkIcon this.network}}}
					<span class="font-mono text-gray-700 text-xs">/{{this.username}}</span>
				</a>
				{{/each}}

				<a href="mailto:{{basics.email}}" class="contact">
					<svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
						<path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
					</svg>
					<span class="font-mono text-gray-700 text-xs">{{basics.email}}</span>
				</a>

				<a href="tel:{{compilePhoneNumber basics.phone}}" class="contact contact--phone">
					<svg viewBox="0 0 24 24" width="14" height="14" fill="white">
						<path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" />
					</svg>
					<span class="font-mono text-xs">{{basics.phone}}</span>
				</a>

			</div>
		</address>

	</header>

	<div class="page__content">
		<main class="max-w-4xl mx-auto py-7 space-y-6 text-gray-700"
			id="main-content">

			{{#if work}}
			<section>
				<h1 class="section__heading">
					Professional Experience
					<span class="text-gray-400 font-mono">(most recent positions, full work history on LinkedIn)</span>
				</h1>
				<div class="mt-3 space-y-5">
					{{#each work}}
					<article class="work__entry">

						<header class="work__entry-header">
							<h2 class="work__entry-title">
								<span class="work__position">{{this.position}}</span>
								<span class="text-gray-400 text-sm">·</span>
								<span class="work__company text-accent">{{this.company}}</span>
							</h2>
							<p class="work__period text-gray-400 text-xs">
								{{formatDate this.startDate}}
								<span> – </span>
								{{#if this.endDate}}
								{{formatDate this.endDate}}
								{{else}}
								<span>Present</span>
								{{/if}}
							</p>
						</header>

						{{#if this.highlights}}
						<ul class="work__highlights-list">
							{{#each this.highlights}}
							<li class="work__highlight text-sm text-gray-700 leading-relaxed">{{.}}{{highlightPunctuation @index ../highlights.length}}</li>
							{{/each}}
						</ul>
						{{/if}}

						{{#if this.summary}}
						<p class="work__highlight mt-1.5 text-sm text-gray-700 leading-relaxed">{{this.summary}}</p>
						{{/if}}

					</article>
					{{/each}}
				</div>
			</section>
			{{/if}}

			{{#if displayedSkills}}
			<section>
				<h1 class="section__heading">Skills</h1>
				<ul class="skills__list">
					{{#each displayedSkills}}
					<li class="skill{{#if this.meta.highlighted}} skill--highlighted{{/if}}">{{this.name}}</li>
					{{/each}}
				</ul>
			</section>
			{{/if}}

		</main>
	</div>

	<div class="page__background-footer"></div>

</body>
</html>
